# Sensitive source and row-level data
data/
*.xlsx
*.xls
*.parquet
*.csv

# Only these reviewed public aggregates may be tracked
!data_demo/
data_demo/*
!data_demo/dashboard_lead_cube.csv
!data_demo/dashboard_order_cube.csv
!data_demo/W4_strategy_comparison.csv
