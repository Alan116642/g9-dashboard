# Models and generated local artifacts
models/
reports/
deliverables/
catboost_info/
tmp/
.venv/
.claude/
node_modules/

# Python and test caches
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.coverage

# Streamlit secrets are never committed
.streamlit/
!.streamlit/
.streamlit/*
!.streamlit/config.toml

